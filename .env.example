# Database
DATABASE_URL=postgresql://user:password@localhost:5432/kumo

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Resend (transactional email — resend.com free tier: 3,000/month)
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Server
PORT=3001

# Google Sheets (for feedback endpoint)
GOOGLE_SHEETS_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id

# Google OAuth (for /auth/google endpoint)
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Version data
APP_MIN_VERSION=1.0.0
APP_LATEST_VERSION=1.0.0
APP_STORE_URL_ANDROID=market://details?id=com.your.app


