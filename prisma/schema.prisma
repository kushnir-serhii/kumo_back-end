generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Subscription {
  free
  free_trial @map("free-trial")
  pro
  cancelled
}

enum Role {
  user
  admin
  super_admin
}

enum AuthProvider {
  email
  google
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  password        String
  authProvider    AuthProvider @default(email)
  firstName       String?
  lastName        String?
  emailConfirmed  Boolean   @default(false)
  subscription    Subscription @default(free)
  nextPaymentDate DateTime?
  trialEndsDate   DateTime?
  productId       String?
  purchaseToken   String?
  role            Role      @default(user)
  notification      Boolean   @default(false)
  analyticsConsent  Boolean   @default(false)
  pushToken         String?
  createdAt         DateTime  @default(now())

  weeklyStreaks        WeeklyStreak[]
  verificationTokens  VerificationToken[]
  passwordResetTokens PasswordResetToken[]
  flowSessions        FlowSession[]

  @@map("users")
}

model WeeklyStreak {
  id     String   @id @default(uuid())
  userId String
  date   DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("weekly_streaks")
}

model VerificationToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model Feedback {
  id        String   @id @default(uuid())
  name      String?
  rating    Int?
  feedback  String?
  createdAt DateTime @default(now())

  @@map("feedbacks")
}

model FlowSession {
  id          Int      @id @default(autoincrement())
  userId      String
  rating      Int?
  completedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("flow_sessions")
}
