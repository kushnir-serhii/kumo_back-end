{
  "name": "kumo-backend",
  "version": "1.0.0",
  "description": "Backend API for Kumo mental wellness app",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "dev:local": "dotenv -e .env.local -- tsx watch src/app.ts",
    "build": "prisma generate && tsc && cp -r src/docs dist/docs",
    "start": "node dist/app.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:local:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:local:push": "dotenv -e .env.local -- prisma db push",
    "db:local:studio": "dotenv -e .env.local -- prisma studio",
    "db:local:reset": "dotenv -e .env.local -- prisma migrate reset",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:stop": "docker compose stop",
    "docker:logs": "docker compose logs -f postgres",
    "docker:reset": "docker compose down -v && docker compose up -d"
  },
  "keywords": [
    "kumo",
    "mental-wellness",
    "api",
    "fastify"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.18.0",
    "@types/uuid": "^9.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.0.0",
    "fastify": "^5.7.2",
    "fastify-plugin": "^5.1.0",
    "google-auth-library": "^9.0.0",
    "googleapis": "^170.1.0",
    "music-metadata": "^11.12.3",
    "@types/nodemailer": "^8.0.0",
    "nodemailer": "^8.0.5",
    "openai": "^4.0.0",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "typescript": "^6.0.0",
    "uuid": "^9.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "dotenv-cli": "^7.0.0",
    "ts-node": "^10.0.0",
    "tsx": "^4.0.0"
  }
}
