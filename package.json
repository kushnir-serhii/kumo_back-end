{
  "name": "kumo-backend",
  "version": "1.0.0",
  "description": "Backend API for Kumo mental wellness app",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "prisma generate && tsc && cp -r src/docs dist/docs",
    "start": "node dist/app.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:local:generate": "prisma generate --schema=prisma/schema.test.prisma",
    "db:local:push": "prisma db push --schema=prisma/schema.test.prisma",
    "db:local:studio": "prisma studio --schema=prisma/schema.test.prisma",
    "db:local:seed": "tsx prisma/seed.ts",
    "db:local:setup": "npm run db:local:generate && npm run db:local:push && npm run db:local:seed"
  },
  "keywords": [
    "kumo",
    "mental-wellness",
    "api",
    "fastify"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^5.22.0",
    "@types/bcrypt": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.0.0",
    "@types/uuid": "^9.0.0",
    "bcrypt": "^5.1.0",
    "dotenv": "^16.0.0",
    "fastify": "^5.7.2",
    "fastify-plugin": "^5.1.0",
    "google-auth-library": "^9.0.0",
    "googleapis": "^170.1.0",
    "music-metadata": "^7.0.0",
    "nodemailer": "^7.0.13",
    "openai": "^4.0.0",
    "prisma": "^5.22.0",
    "typescript": "^5.0.0",
    "uuid": "^9.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "dotenv-cli": "^7.0.0",
    "ts-node": "^10.0.0",
    "tsx": "^4.0.0"
  }
}
